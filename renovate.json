{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/Zurich",
  "schedule": [
    "before 06:00 on monday"
  ],
  "dependencyDashboard": true,
  "semanticCommits": "enabled",
  "labels": [
    "dependencies"
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "platformAutomerge": true,
  "vulnerabilityAlerts": {
    "labels": [
      "security",
      "dependencies"
    ],
    "vulnerabilityFixStrategy": "lowest"
  },
  "packageRules": [
    {
      "description": "Automerge non-major vulnerability fixes",
      "matchJsonata": [
        "$exists(vulnerabilityFixVersion) and updateType != 'major'"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge GitHub Actions maintenance updates",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "digest",
        "pin",
        "pinDigest",
        "patch",
        "minor"
      ],
      "semanticCommitType": "chore",
      "semanticCommitScope": "ci",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge development dependency maintenance",
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps-dev",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge releasable runtime dependency updates",
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "dependencies",
        "optionalDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "semanticCommitType": "fix",
      "semanticCommitScope": "deps",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Require manual approval for major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "dependencyDashboardApproval": true
    }
  ]
}
